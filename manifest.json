{
  "manifest_version": 3,
  "name": "YouTube Transcript Copier",
  "version": "2.0",
  "description": "Robust transcript copier compatible with modern YouTube updates.",
  "permissions": [
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/watch?v=*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}